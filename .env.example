# ── Analytics (optional — scripts load only when set) ─────────────
# GA4 measurement ID, e.g. G-XXXXXXXXXX
VITE_GA4_ID=
# Microsoft Clarity project ID
VITE_CLARITY_ID=

# ── Commerce ───────────────────────────────────────────────────────
# Hosted checkout for the digital program (Schooler / רב מסר). Defaults to
# the production Schooler payment page when unset; set only to override.
VITE_CHECKOUT_URL=

# ── WhatsApp ───────────────────────────────────────────────────────
# Overrides the intake-bot number (default 972559925725). Emergency lever:
# point it at the business line 972559966175 to bypass the bot without a
# deploy if the bot flow is down.
VITE_WHATSAPP_BOT_NUMBER=

# ── Lead intake ────────────────────────────────────────────────────
# Supabase Edge Function receiving website leads. Defaults to the
# production function when unset.
VITE_LEADS_INTAKE_URL=
# Make.com webhook mirroring every lead into the per-product Google
# Sheets (backup + partner sharing). Defaults to the production webhook.
VITE_LEADS_SHEETS_WEBHOOK_URL=
